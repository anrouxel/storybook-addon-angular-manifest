{
  "name": "@anrouxel/storybook-addon-angular-manifest",
  "version": "1.0.1",
  "description": "Storybook addon to generate a manifest of Angular components",
  "keywords": [
    "storybook-addon",
    "storybook",
    "angular",
    "manifest",
    "mcp",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/anrouxel/storybook-addon-angular-manifest.git"
  },
  "license": "MIT",
  "author": "Antonin Rouxel",
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./preset": "./dist/preset.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "*.js",
    "*.d.ts"
  ],
  "scripts": {
    "prebuild": "node -e \"fs.rmSync('./dist', { recursive: true, force: true })\"",
    "build": "tsdown",
    "build:watch": "npm run build -- --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "biome check ./src",
    "check:apply": "pnpm check --write",
    "check:apply-unsafe": "pnpm check --write --unsafe",
    "check:ci": "biome ci ./src",
    "format": "biome format ./src",
    "format:write": "pnpm format --write",
    "version-packages": "changeset version && pnpm check:apply",
    "release": "changeset publish"
  },
  "dependencies": {
    "@compodoc/compodoc": "^2.0.0",
    "comment-parser": "^1.4.7",
    "empathic": "^2.0.1",
    "pathe": "^2.0.3",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@angular/core": "^22.0.4",
    "@biomejs/biome": "2.5.1",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "next",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@commitlint/types": "^21.2.0",
    "@storybook/angular-vite": "next",
    "@types/node": "^26.0.1",
    "lefthook": "^2.1.9",
    "memfs": "^4.57.8",
    "npm-run-all2": "^9.0.2",
    "storybook": "next",
    "ts-dedent": "^2.3.0",
    "tsdown": "^0.22.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "storybook": "^10.5.0-alpha.9"
  },
  "publishConfig": {
    "access": "public"
  },
  "storybook": {
    "displayName": "Storybook Addon Angular Manifest",
    "supportedFrameworks": [
      "angular",
      "angular-vite"
    ],
    "icon": "https://angular.io/assets/images/logos/angular/angular.svg"
  },
  "packageManager": "pnpm@11.9.0"
}
